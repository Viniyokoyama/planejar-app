generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  plan      String   @default("starter")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businesses Business[]
  reports    Report[]
  sessions   ConsultancySession[]
}

model Business {
  id             String   @id @default(cuid())
  userId         String
  name           String
  segment        String
  targetAudience String?
  avgTicket      Float?
  description    String?
  openingHours   String?
  createdAt      DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports Report[]
}

model Report {
  id           String   @id @default(cuid())
  userId       String
  businessId   String?
  type         String   @default("completo")
  status       String   @default("processing")
  overallScore Float?
  data         String   @default("{}")
  createdAt    DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  business    Business?    @relation(fields: [businessId], references: [id])
  addresses   Address[]
  competitors Competitor[]
  riskAlerts  RiskAlert[]
}

model Address {
  id           String   @id @default(cuid())
  reportId     String
  rawAddress   String
  lat          Float?
  lng          Float?
  scores       String   @default("{}")
  overallScore Float?
  analysis     String?
  isSuggested  Boolean  @default(false)
  createdAt    DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model Competitor {
  id           String   @id @default(cuid())
  reportId     String
  name         String
  address      String?
  platform     String?
  rating       Float?
  reviewsCount Int?
  sentimentPos Float?
  sentimentNeg Float?
  strengths    String   @default("[]")
  weaknesses   String   @default("[]")
  createdAt    DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model RiskAlert {
  id             String   @id @default(cuid())
  reportId       String
  type           String
  severity       String
  title          String
  description    String
  impactEstimate Float?
  createdAt      DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model Specialist {
  id            String  @id @default(cuid())
  name          String
  specialty     String
  bio           String?
  photoUrl      String?
  rating        Float   @default(5.0)
  sessionsCount Int     @default(0)
  isActive      Boolean @default(true)

  sessions ConsultancySession[]
}

model ConsultancySession {
  id           String   @id @default(cuid())
  userId       String
  specialistId String
  reportId     String?
  scheduledAt  DateTime
  status       String   @default("scheduled")
  meetingUrl   String?
  notes        String?
  rating       Int?
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id])
  specialist Specialist @relation(fields: [specialistId], references: [id])
}
